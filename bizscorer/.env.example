# Add these in Vercel Dashboard → Settings → Environment Variables

# Required: Anthropic API key for Claude AI scanning
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Required: Resend API key for email report delivery
RESEND_API_KEY=re_your-key-here

# Required: Google Maps API key for Places Autocomplete (VITE_ prefix exposes to client)
VITE_GOOGLE_MAPS_KEY=AIza-your-key-here
